<!-- Block: Services -->

{% if data %}

	<div id='services-block' class="front-block views-element-container block" data-aos="fade-right">
		<div class="container">

			<h2 class="block-title"> {{ 'Services'|t }} </h2>

			<div class="block-content">
				<div class="field field--name-body field--type-text-with-summary field--label-hidden field-item">
					<div id="services-slider" class="services owl-carousel owl-theme owl-loaded owl-drag">

						<!-- Services -->
						{% for item in data %}

							<div class="service">
								<div class="service-icon">
									<img class="svg-icon" src={{ file_url(item.get('field_image').entity.uri.value) }} alt="service">
								</div>
								<h3> {{ item.get('title').value }} </h3>
								<p class="summary"> {{ item.get('field_summary').value }} </p>
								<p><a class="button" href="{{ url('entity.node.canonical', {'node': item.id}) }}"> 
									{{ 'Read more'|t }} 
								</a></p>
							</div>

						{% endfor %}

					</div>
				</div>
			</div>

		</div>
	</div>
  
{% endif %}	