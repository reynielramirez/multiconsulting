<!-- Block: Testimonials -->

{% if data %}

	<div id='testimonials-block' class="front-block views-element-container block">
		<div class="container">

			<div data-aos="fade-right">

				<h2 class="block-title"> {{ 'Testimonials'|t }} </h2>

				<div class="block-content">

					<div class="field field--name-body field--type-text-with-summary field--label-hidden field-item">
						<div id="testimonials-slider" class="services owl-carousel owl-theme owl-loaded owl-drag">

							<!-- Testimonials -->
							{% for item in data %}	

								<div class="box-item">
									<div class="box-top">
										<div class="icon">
											<img src={{ file_url(item.get('field_image').entity.uri.value) }} alt="testimonial">
										</div>
										<div class="info">
											<h4> {{ item.get('title').value }} </h4>	
											<h6 class="date"> {{ item.get('field_date').value|date('U')|format_date('custom', 'D, j M Y') }} </h6>
											<h6> {{ item.get('field_name').value }} 
												<span>
													( {{ item.get('field_position').entity.label }} )
												</span> 
											</h6>	
										</div>
									</div>
									<hr>
									<p class="summary"> {{ item.get('field_summary').value }} </p>
								</div>

							{% endfor %}

						</div>
	
					</div>

				</div>
			</div>

		</div>
	</div>
  
{% endif %}	