
{#
/**
 * @file
 * Theme override for  term fields.
 */
#}

<div id='field-products-view' class="node-taxonomy-container">
  <h3 class="view-title values-title">{{"Sub-Productos"|t}}</h3>
    <div class="separator"></div>
		<div class='products-items view-content container'>

			<div class="container">
				<div class="items">
          {% for item in items %}
            {% set referenced_entity = item.content['#node'] %}
            {% if referenced_entity %}
              <div class="product service">
                <h3>
                  {{ referenced_entity.get('title').value }}
                </h3>
                <div class="product-icon">
                  <img src={{ file_url(referenced_entity.get('field_image').entity.uri.value) }} alt="product name">
                </div>
                <p class="summary">
                  {{ referenced_entity.get('field_summary').value }}
                </p>
                <p>
                  <a class="button read-more" href="{{ url('entity.node.canonical', {'node': referenced_entity.id}) }}">
                    {{ 'Read more'|t }}
                    <i class="fas fa-arrow-right"></i>
                  </a>
                </p> 
              </div>
            {% endif %}
         {% endfor %}
        </div>
      </div>
    </div> 
</div> <!--/.node-taxonomy-container -->
{{ attach_library('xara/product-service') }}

