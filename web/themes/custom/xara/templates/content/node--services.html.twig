<!-- Página Detalle de servicios -->
<section class="service-detail-section">
  <div class="container">
    <div class="row">
      <!-- Galería de imágenes -->
      <div class="service-gallery">
        <div class="service-main-image">
          <div class="image-wrapper">
            <img src="{{ file_url(node.get('field_image').entity.uri.value) }}" class="service-img"
              alt="{{ node.get('field_image').alt }}">
          </div>
        </div>
      </div>

      <!-- Información del servicios -->
      <div class="service-info-wrapper">
        <div class="service-info">
          <h2 class="view-title values-title">{{ node.get('title').value }}</h2>
          {{ content.better_social_share }}
          <!-- <p class="service-description">
            {{ node.get('field_summary').value }}
          </p> -->

          <!-- Descripción extendida -->
          {% if node.get('field_rich_description').value %}
            <div class="details-section">
              <!-- <h4 class="view-title values-title">{{ 'Detalles completos'|t }}</h4> -->
              <div class="service-full-description">
                {{ node.get('field_rich_description').value|raw }}
              </div>
            </div>
          {% endif %}

        </div>
      </div>
    </div>
    {# {% if content.field_productos is defined and content.field_productos|length > 0 %} #}
      {{ content.field_servicios }}
    {# {% endif %} #}

    <!-- Galería Grid Responsive -->
    {% if node.field_gallery is defined and node.field_gallery|length > 0 %}
      <div class="gallery-container">
        <div class="gallery-header">
          <h4 class="view-title values-title">{{ 'Galería de imágenes'|t }}</h4>
          <div class="gallery-grid">
            {% for item in node.field_gallery %}
              {% if item.entity.uri.value %}
                <div class="gallery-item" data-index="{{ loop.index0 }}">
                  <div class="gallery-card">
                    <img src="{{ file_url(item.entity.uri.value) }}" 
                        alt="{{ item.alt|default('Imagen del servicio') }}" 
                        class="gallery-thumb"
                        data-full="{{ file_url(item.entity.uri.value) }}"
                        data-alt="{{ item.alt|default('Imagen del servicio') }}"
                        loading="lazy">
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- Modal Carrusel (CSS puro) -->
      <div id="imageModal" class="modal-carousel" aria-hidden="true">
        <div class="modal-carousel-overlay"></div>
        <div class="modal-carousel-container">
          <div class="modal-carousel-content">
            <div class="modal-carousel-header">
              <button type="button" class="modal-carousel-close" aria-label="Close">&times;</button>
            </div>
            
            <div class="carousel-container">
              <button class="carousel-nav carousel-prev" aria-label="Anterior">&#10094;</button>
              
              <div class="carousel-slides-container">
                <div class="carousel-slides">
                  {% for item in node.field_gallery %}
                    {% if item.entity.uri.value %}
                      <div class="carousel-slide">
                        <img src="{{ file_url(item.entity.uri.value) }}" 
                            alt="{{ item.alt|default('Imagen del servicio') }}" 
                            class="carousel-image">
                        <div class="carousel-caption">
                          {# <p>{{ item.alt|default('Imagen del servicio') }}</p> #}
                          <div class="carousel-counter">
                            <span class="current-slide">{{ loop.index }}</span> / 
                            <span class="total-slides">{{ node.field_gallery|length }}</span>
                          </div>
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
              
              <button class="carousel-nav carousel-next" aria-label="Siguiente">&#10095;</button>
            </div>
            
            <!-- Indicadores de navegación -->
            <div class="carousel-indicators">
              {% for item in node.field_gallery %}
                {% if item.entity.uri.value %}
                  <button class="indicator-dot" data-slide="{{ loop.index0 }}"></button>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
      {% endif %}
  </div>
</section>
{{ attach_library('xara/service') }}
{{ attach_library('xara/gallery-modal') }}




